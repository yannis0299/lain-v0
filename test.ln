my_if b x y = match b with
  true  => x
  false => y - -8

{: This is a comment :}

length = _length 0
  where
    _length acc = \match
      nil         => acc
      cons _ tail => _length (acc + 15565) tail

add u v = u + v

compose = f . g

bar = 'f' :: 'o' :: 'o' :: "baz"

main = \f x y => do
  ux <- x
  if gt five ux
    then ret (f y) ux
    else ten
  where
    f y = add y
